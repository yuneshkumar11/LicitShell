<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/libraryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <LinearLayout
        android:id="@+id/libraryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_community_tab_inactive">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/library_page_title"
                android:textColor="@color/home_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search" />

            <EditText
                android:id="@+id/etSearchTopics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/search_rights_hint"
                android:textColor="@color/home_text_primary"
                android:textColorHint="@color/home_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/libraryContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_library_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/libraryHeader">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnCategoryAll"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_library_chip_active"
                            android:minWidth="56dp"
                            android:paddingHorizontal="18dp"
                            android:text="@string/library_category_all"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@null" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnCategorySafety"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_library_chip_inactive"
                            android:minWidth="92dp"
                            android:paddingHorizontal="18dp"
                            android:text="@string/library_category_safety"
                            android:textAllCaps="false"
                            android:textColor="@color/home_text_primary"
                            android:textStyle="bold"
                            app:backgroundTint="@null" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnCategoryEducation"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_library_chip_inactive"
                            android:minWidth="112dp"
                            android:paddingHorizontal="18dp"
                            android:text="@string/library_category_education"
                            android:textAllCaps="false"
                            android:textColor="@color/home_text_primary"
                            android:textStyle="bold"
                            app:backgroundTint="@null" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnCategoryJustice"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_library_chip_inactive"
                            android:minWidth="96dp"
                            android:paddingHorizontal="18dp"
                            android:text="@string/library_category_justice"
                            android:textAllCaps="false"
                            android:textColor="@color/home_text_primary"
                            android:textStyle="bold"
                            app:backgroundTint="@null" />
                    </LinearLayout>
                </HorizontalScrollView>

                <LinearLayout
                    android:id="@+id/libraryTopicsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvNoLibraryTopics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/no_library_topics"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvLibraryVideosHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/library_video_heading"
                    android:textColor="@color/home_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLibraryVideosDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/library_video_desc"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/libraryVideosContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
