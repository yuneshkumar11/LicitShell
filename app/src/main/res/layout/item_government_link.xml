<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:background="@drawable/bg_home_info_card"
    android:elevation="3dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGovTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/home_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvGovDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/home_text_secondary"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnOpenGov"
        android:layout_width="wrap_content"
        android:layout_height="46dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_government_button"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="@string/open_website"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>
